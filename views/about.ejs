<%- include('partials/header') %>

<section class="page-head">
    <div class="container">
        <p class="eyebrow"><span class="text-accent">$</span> cd ~/about</p>
        <h1>About Me</h1>
        <p class="page-sub">// the engineer behind the commits</p>
    </div>
</section>

<section class="about-section">
    <div class="container">
        <div class="about-grid">
            <div class="about-content">
                <div class="about-profile">
                    <img src="<%= data.avatar %>" alt="<%= data.fullName %>" class="about-avatar">
                </div>
                <h2>Hello! I'm <span class="text-accent"><%= data.fullName %></span></h2>
                <p class="about-text"><%= data.about %></p>

                <div class="about-info">
                    <div class="info-item">
                        <i class="fas fa-user"></i>
                        <div>
                            <h4>Full Name</h4>
                            <p><%= data.fullName %></p>
                            <p class="text-accent">Known as "<%= data.nickname %>"</p>
                        </div>
                    </div>
                    <div class="info-item">
                        <i class="fas fa-birthday-cake"></i>
                        <div>
                            <h4>Age</h4>
                            <p><%= data.age %> years old (<%= data.birthdate %>)</p>
                        </div>
                    </div>
                    <div class="info-item">
                        <i class="fas fa-graduation-cap"></i>
                        <div>
                            <h4>Education</h4>
                            <p><%= data.degree %></p>
                            <p><%= data.college %></p>
                            <p class="text-accent"><%= data.status %></p>
                        </div>
                    </div>
                    <div class="info-item">
                        <i class="fas fa-briefcase"></i>
                        <div>
                            <h4>Role</h4>
                            <p><%= data.title %></p>
                        </div>
                    </div>
                    <div class="info-item">
                        <i class="fas fa-robot"></i>
                        <div>
                            <h4>AI Tools</h4>
                            <p>Claude Code, DeepSeek, MCP Orchestration</p>
                        </div>
                    </div>
                    <div class="info-item">
                        <i class="fab fa-github"></i>
                        <div>
                            <h4>GitHub</h4>
                            <p><a href="<%= data.github %>" target="_blank">@<%= data.githubUsername %></a></p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="about-skills">
                <h3>What I Do</h3>
                <div class="skill-category">
                    <h4><i class="fas fa-code"></i> Languages & Frameworks</h4>
                    <ul>
                        <% data.skills.languages.forEach(lang => { %>
                            <li><%= lang %></li>
                        <% }); %>
                    </ul>
                </div>
                <div class="skill-category">
                    <h4><i class="fas fa-database"></i> Databases</h4>
                    <ul>
                        <% data.skills.databases.forEach(db => { %>
                            <li><%= db %></li>
                        <% }); %>
                    </ul>
                </div>
                <div class="skill-category">
                    <h4><i class="fas fa-server"></i> Infrastructure & Security</h4>
                    <ul>
                        <% data.skills.infrastructure.forEach(item => { %>
                            <li><%= item %></li>
                        <% }); %>
                    </ul>
                </div>
                <div class="skill-category">
                    <h4><i class="fas fa-robot"></i> AI Tooling & Automation</h4>
                    <ul>
                        <% data.skills.aiTools.forEach(item => { %>
                            <li><%= item %></li>
                        <% }); %>
                    </ul>
                </div>
                <div class="skill-category">
                    <h4><i class="fas fa-microchip"></i> Hardware & Embedded</h4>
                    <ul>
                        <% data.skills.hardware.forEach(item => { %>
                            <li><%= item %></li>
                        <% }); %>
                    </ul>
                </div>
            </div>
        </div>

        <div class="experience-section">
            <h2>Experience</h2>
            <div class="timeline">
                <% data.experience.forEach(exp => { %>
                    <div class="timeline-item">
                        <div class="timeline-marker"></div>
                        <div class="timeline-content">
                            <h3><%= exp.title %></h3>
                            <h4><%= exp.company %></h4>
                            <p class="period"><i class="far fa-calendar"></i> <%= exp.period %></p>
                            <p><%= exp.description %></p>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>

        <div class="certificates-section">
            <h2>Certificates & Awards</h2>
            <div class="certificates-grid">
                <% data.certificates.forEach((cert, index) => { %>
                    <div class="certificate-card" onclick="openCertModal(<%= index %>)">
                        <div class="certificate-image-wrapper">
                            <img src="<%= cert.image %>" alt="<%= cert.title %>" class="certificate-thumbnail" loading="lazy">
                            <div class="certificate-overlay">
                                <i class="fas fa-search-plus"></i>
                            </div>
                        </div>
                        <div class="certificate-card-body">
                            <div class="certificate-card-header">
                                <div class="certificate-icon">
                                    <i class="<%= cert.icon %>"></i>
                                </div>
                                <div>
                                    <h3><%= cert.title %></h3>
                                    <span class="certificate-category"><%= cert.category %></span>
                                </div>
                            </div>
                            <div class="certificate-meta">
                                <p><i class="fas fa-building"></i> <%= cert.issuer %></p>
                                <p><i class="far fa-calendar"></i> <%= cert.date %></p>
                                <p><i class="fas fa-info-circle"></i> <%= cert.details %></p>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>
    </div>
</section>

<!-- Certificate Modal / Lightbox -->
<div class="cert-modal" id="certModal">
    <div class="cert-modal-overlay" onclick="closeCertModal()"></div>
    <div class="cert-modal-content">
        <button class="cert-modal-close" onclick="closeCertModal()">&times;</button>
        <button class="cert-modal-nav cert-modal-prev" onclick="navigateCert(-1)"><i class="fas fa-chevron-left"></i></button>
        <img src="" alt="" id="certModalImage" class="cert-modal-image">
        <button class="cert-modal-nav cert-modal-next" onclick="navigateCert(1)"><i class="fas fa-chevron-right"></i></button>
        <div class="cert-modal-info">
            <h3 id="certModalTitle"></h3>
            <p id="certModalDetails"></p>
        </div>
    </div>
</div>

<script>
    const certificates = <%- JSON.stringify(data.certificates) %>;
    let currentCertIndex = 0;

    function openCertModal(index) {
        currentCertIndex = index;
        updateModal();
        document.getElementById('certModal').classList.add('active');
        document.body.style.overflow = 'hidden';
    }

    function closeCertModal() {
        document.getElementById('certModal').classList.remove('active');
        document.body.style.overflow = '';
    }

    function navigateCert(direction) {
        currentCertIndex = (currentCertIndex + direction + certificates.length) % certificates.length;
        updateModal();
    }

    function updateModal() {
        const cert = certificates[currentCertIndex];
        document.getElementById('certModalImage').src = cert.image;
        document.getElementById('certModalImage').alt = cert.title;
        document.getElementById('certModalTitle').textContent = cert.title;
        document.getElementById('certModalDetails').textContent = cert.issuer + ' | ' + cert.date;
    }

    document.addEventListener('keydown', (e) => {
        const modal = document.getElementById('certModal');
        if (!modal.classList.contains('active')) return;
        if (e.key === 'Escape') closeCertModal();
        if (e.key === 'ArrowLeft') navigateCert(-1);
        if (e.key === 'ArrowRight') navigateCert(1);
    });
</script>

<%- include('partials/footer') %>
